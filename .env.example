# ============================================================
# ERYES DASH 環境変数一覧
# すべて未設定でも「デモモード」（メモリ内データ＋LINEモック）で動作します。
# 本番運用時は .env.local（ローカル）/ Vercel の環境変数に設定してください。
# ============================================================

# ---- アプリ基本設定 ----
# セッションCookieの署名鍵（本番では必ずランダムな長い文字列に変更）
# 生成例: openssl rand -hex 32
AUTH_SECRET=

# 定時バッチ(/api/cron/reminder)の認証トークン。Vercel Cron が自動で付与する値と一致させる
# 生成例: openssl rand -hex 16
CRON_SECRET=

# アプリの公開URL（リッチメニュー設定やREADME手順で使用）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase（未設定の場合はメモリ内デモデータで動作）----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- LINE Messaging API（未設定の場合はモック送信＝画面・ログで確認できる）----
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ---- LIFF（カウンセリングフォーム）----
# 未設定の場合、フォームはデモモード（テスト用ユーザーIDを手入力）で動作
NEXT_PUBLIC_LIFF_ID=
